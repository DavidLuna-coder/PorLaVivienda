---
import { urbanaData } from "../lib/data";
import type { PersonaFiscalData } from "../lib/data";

/**
 * Mapa coroplético de España por provincias para "Por la vivienda".
 *
 * - Color = concentración de la propiedad en grandes tenedores
 *   (titulares con MÁS DE 10 inmuebles urbanos, criterio de la Ley 12/2023
 *   por la que se define al "gran tenedor"). Se calcula sumando los tramos
 *   11-25, 26-100 y +100 inmuebles del bloque de Propiedades Urbanas (PU).
 * - Click en una provincia => zoom a su bounding box + 3 métricas clave.
 * - Las provincias forales (Álava, Bizkaia, Gipuzkoa y Navarra) no figuran
 *   en el Catastro común, por lo que aparecen en gris ("sin datos").
 *
 * El GeoJSON debe estar en  public/data/provincias.geojson
 * (los nombres de cada feature coinciden con la columna PROVINCIA del CSV).
 */

const GEOJSON_URL = "/data/provincias.geojson";

// Umbral de "gran tenedor" (inmuebles). Cambia aquí si quieres otro corte.
const UMBRAL_GRAN_TENEDOR = 10;

const sumPF = (p: PersonaFiscalData) =>
  p.fisNA + p.fisEX + p.sociedades + p.entidadesSinal + p.entidadesSinpj +
  p.entidadesExt + p.aapp + p.entidadesNdef + p.otros;

interface ProvStat {
  titulares: number;
  inmuebles: number;
  granTenedor: number; // inmuebles en manos de titulares con > UMBRAL inmuebles
  municipios: number;
  pct: number;         // % de inmuebles de gran tenedor
}

const byProv: Record<string, ProvStat> = {};
for (const r of urbanaData) {
  const s = (byProv[r.province] ??= {
    titulares: 0, inmuebles: 0, granTenedor: 0, municipios: 0, pct: 0,
  });
  s.titulares += r.totalOwners;
  s.inmuebles += r.totalProperties;
  s.municipios += 1;
  // Tramos por encima de 10 inmuebles (gran tenedor)
  s.granTenedor +=
    sumPF(r.propiedades.elevenToTwentyFive) +
    sumPF(r.propiedades.twentySixToHundred) +
    sumPF(r.propiedades.moreThan100);
}
for (const k of Object.keys(byProv)) {
  const s = byProv[k];
  s.pct = s.inmuebles ? (s.granTenedor / s.inmuebles) * 100 : 0;
}

// Totales nacionales (estado inicial del panel)
const nacional = Object.values(byProv).reduce(
  (a, s) => ({
    titulares: a.titulares + s.titulares,
    inmuebles: a.inmuebles + s.inmuebles,
    granTenedor: a.granTenedor + s.granTenedor,
    municipios: a.municipios + s.municipios,
  }),
  { titulares: 0, inmuebles: 0, granTenedor: 0, municipios: 0 }
);
const nacionalPct = nacional.inmuebles
  ? (nacional.granTenedor / nacional.inmuebles) * 100
  : 0;

const year = urbanaData[0]?.year ?? 2024;
const numProv = Object.keys(byProv).length;
---

<section class="plv-map-section bg-base-200">
  <header class="plv-head">
    <p class="plv-eyebrow">Catastro · Multitenencia · {year}</p>
    <h2 class="plv-title">¿Quién acumula la vivienda?</h2>
    <p class="plv-sub">
      Concentración de la propiedad urbana residencial por provincia. El color mide el
      porcentaje de inmuebles en manos de <strong>grandes tenedores</strong>
      (más de {UMBRAL_GRAN_TENEDOR} inmuebles). Pulsa una provincia para ampliarla.
    </p>
  </header>

  <div class="plv-grid">
    <!-- MAPA -->
    <div class="plv-stage">
      <svg id="plv-map" role="img" aria-label="Mapa de provincias de España"></svg>
      <div id="plv-tip" class="plv-tip"></div>
      <button id="plv-reset" class="btn btn-sm btn-neutral plv-reset">↺ Ver toda España</button>

      <!-- Leyenda -->
      <div class="plv-legend">
        <span class="plv-legend-label">% inmuebles de gran tenedor</span>
        <div id="plv-legend-bar" class="plv-legend-bar"></div>
        <div class="plv-legend-ticks">
          <span>0%</span><span>5%</span><span>≥10%</span>
        </div>
        <div class="plv-legend-na"><span class="plv-na-swatch"></span> Sin datos (catastro foral)</div>
      </div>
    </div>

    <!-- PANEL -->
    <aside class="plv-panel">
      <p id="plv-scope" class="plv-scope">España · {numProv} provincias con datos</p>
      <h3 id="plv-name" class="plv-name">Vista general</h3>

      <div class="stats stats-vertical plv-stats shadow">
        <div class="stat">
          <div class="stat-title">Inmuebles residenciales</div>
          <div id="plv-stat-inm" class="stat-value text-secondary">—</div>
          <div id="plv-stat-inm-d" class="stat-desc">urbana residencial</div>
        </div>
        <div class="stat">
          <div class="stat-title">Titulares</div>
          <div id="plv-stat-tit" class="stat-value">—</div>
          <div id="plv-stat-tit-d" class="stat-desc">personas y entidades</div>
        </div>
        <div class="stat">
          <div class="stat-title">En manos de grandes tenedores</div>
          <div id="plv-stat-gt" class="stat-value text-accent">—</div>
          <div id="plv-stat-gt-d" class="stat-desc">+{UMBRAL_GRAN_TENEDOR} inmuebles</div>
        </div>
      </div>

      <div class="plv-bar-wrap">
        <div class="plv-bar-track"><div id="plv-bar" class="plv-bar-fill"></div></div>
        <p id="plv-muni" class="plv-muni">—</p>
      </div>

      <p class="plv-foot">
        Fuente: Dirección General del Catastro. País Vasco y Navarra disponen de
        catastro foral propio y no se incluyen.
      </p>
    </aside>
  </div>
</section>

<script
  is:inline
  define:vars={{
    STATS: byProv,
    NAC: { ...nacional, pct: nacionalPct },
    GEOJSON_URL,
    UMBRAL: UMBRAL_GRAN_TENEDOR,
    NUMPROV: numProv,
  }}
>
  const fmt = new Intl.NumberFormat("es-ES");
  const pct = (v) => v.toFixed(1).replace(".", ",") + " %";

  function loadD3() {
    return new Promise((res, rej) => {
      if (window.d3) return res();
      const s = document.createElement("script");
      s.src = "https://cdn.jsdelivr.net/npm/d3@7";
      s.onload = () => res();
      s.onerror = rej;
      document.head.appendChild(s);
    });
  }

  function cssVar(name, fallback) {
    const v = getComputedStyle(document.documentElement).getPropertyValue(name).trim();
    return v || fallback;
  }

  (async () => {
    await loadD3();
    const d3 = window.d3;
    let geo;
    try {
      geo = await (await fetch(GEOJSON_URL)).json();
    } catch (e) {
      document.getElementById("plv-map").outerHTML =
        '<p style="padding:2rem;color:var(--color-error)">No se pudo cargar ' +
        GEOJSON_URL + '. Copia provincias.geojson en public/data/.</p>';
      return;
    }

    const stage = document.querySelector(".plv-stage");
    const svg = d3.select("#plv-map");
    const tip = d3.select("#plv-tip");

    // Escala de color (clara -> teja), coherente con el tema
    const RAMP = ["#f4ede3", "#ffe0c6", "#ffb088", "#ff8f57", "#ee6b33", "#b23c12"];
    const color = d3.scaleSequential(d3.interpolateRgbBasis(RAMP)).domain([0, 10]).clamp(true);
    const NA = cssVar("--color-base-300", "#d9d9dd");

    // Leyenda (gradiente)
    document.getElementById("plv-legend-bar").style.background =
      "linear-gradient(90deg," + RAMP.join(",") + ")";

    const projection = d3.geoMercator();
    const path = d3.geoPath(projection);

    const gZoom = svg.append("g");
    const gReg = gZoom.append("g");
    const gOv = gZoom.append("g");

    let selected = null, W = 0, H = 0;

    const zoom = d3.zoom().scaleExtent([1, 16]).on("zoom", (ev) => {
      gZoom.attr("transform", ev.transform);
      gReg.selectAll("path").style("stroke-width", 0.6 / ev.transform.k + "px");
      gOv.select(".plv-canary-box").attr("stroke-width", 1 / ev.transform.k);
    });
    svg.call(zoom).on("dblclick.zoom", null);

    function statOf(name) { return STATS[name]; }

    const regions = gReg.selectAll("path")
      .data(geo.features)
      .join("path")
        .attr("class", "plv-region")
        .attr("tabindex", 0)
        .attr("role", "button")
        .attr("aria-label", (d) => d.properties.display)
        .attr("fill", (d) => {
          const s = statOf(d.properties.name);
          return s ? color(s.pct) : NA;
        })
        .on("mousemove", (ev, d) => {
          const r = stage.getBoundingClientRect();
          const s = statOf(d.properties.name);
          tip.style("left", ev.clientX - r.left + "px")
             .style("top", ev.clientY - r.top + "px")
             .style("opacity", 1)
             .html("<b>" + d.properties.display + "</b>" +
                   (s ? "<br>" + pct(s.pct) + " gran tenedor" : "<br>sin datos"));
        })
        .on("mouseleave", () => tip.style("opacity", 0))
        .on("click", (ev, d) => { ev.stopPropagation(); select(d); })
        .on("keydown", (ev, d) => {
          if (ev.key === "Enter" || ev.key === " ") { ev.preventDefault(); select(d); }
        });

    svg.on("click", () => reset());

    function canaryBounds() {
      const features = geo.features.filter((d) => d.properties.canarias);
      if (!features.length) return null;
      let minLng = Infinity, minLat = Infinity, maxLng = -Infinity, maxLat = -Infinity;
      for (const f of features) {
        const [[w, s], [e, n]] = d3.geoBounds(f);
        minLng = Math.min(minLng, w); minLat = Math.min(minLat, s);
        maxLng = Math.max(maxLng, e); maxLat = Math.max(maxLat, n);
      }
      return [[minLng, minLat], [maxLng, maxLat]];
    }

    function drawOverlay() {
      gOv.selectAll("*").remove();
      const cb = canaryBounds();
      if (!cb) return;
      const [[w, s], [e, n]] = cb;
      const m = 0.4;
      const p1 = projection([w - m, n + m]);
      const p2 = projection([e + m, s - m]);
      const x = Math.min(p1[0], p2[0]) - 4, y = Math.min(p1[1], p2[1]) - 4;
      const bw = Math.abs(p2[0] - p1[0]) + 8, bh = Math.abs(p2[1] - p1[1]) + 8;
      gOv.append("rect").attr("class", "plv-canary-box")
        .attr("x", x).attr("y", y).attr("width", bw).attr("height", bh).attr("rx", 6)
        .attr("fill", "none")
        .attr("stroke", cssVar("--color-base-300", "#d9d9dd"))
        .attr("stroke-dasharray", "4 4")
        .attr("stroke-width", "1");
      gOv.append("text").attr("class", "plv-canary-text")
        .attr("x", x + 6).attr("y", y - 6).text("Canarias")
        .attr("font-family", "ui-monospace, monospace")
        .attr("font-size", "9px")
        .attr("letter-spacing", ".1em")
        .attr("fill", cssVar("--color-base-content", "#1f2937"))
        .attr("opacity", "0.6")
        .style("text-transform", "uppercase");
    }

    function layout() {
      W = stage.clientWidth; H = stage.clientHeight;
      svg.attr("viewBox", `0 0 ${W} ${H}`);
      const pad = Math.min(W, H) * 0.05;
      projection.fitExtent([[pad, pad], [W - pad, H - pad]], geo);
      gReg.selectAll("path").attr("d", path);
      drawOverlay();
      if (selected) zoomTo(selected, false);
    }

    function zoomTo(d, animate) {
      const [[x0, y0], [x1, y1]] = path.bounds(d);
      const dx = x1 - x0, dy = y1 - y0;
      const cx = (x0 + x1) / 2, cy = (y0 + y1) / 2;
      const scale = Math.min(13, 0.85 / Math.max(dx / W, dy / H));
      const t = d3.zoomIdentity.translate(W / 2, H / 2).scale(scale).translate(-cx, -cy);
      (animate ? svg.transition().duration(760).ease(d3.easeCubicInOut) : svg)
        .call(zoom.transform, t);
    }

    function reset() {
      selected = null;
      regions.classed("sel", false).classed("dim", false);
      svg.transition().duration(720).ease(d3.easeCubicInOut)
         .call(zoom.transform, d3.zoomIdentity);
      document.getElementById("plv-reset").classList.remove("show");
      fillPanel(null);
    }
    document.getElementById("plv-reset")
      .addEventListener("click", (e) => { e.stopPropagation(); reset(); });

    function select(d) {
      selected = d;
      regions.classed("sel", (x) => x === d).classed("dim", (x) => x !== d);
      zoomTo(d, true);
      document.getElementById("plv-reset").classList.add("show");
      fillPanel(d);
    }

    function setStat(id, value) { document.getElementById(id).textContent = value; }

    function fillPanel(d) {
      if (!d) {
        document.getElementById("plv-scope").textContent =
          "España · " + NUMPROV + " provincias con datos";
        document.getElementById("plv-name").textContent = "Vista general";
        setStat("plv-stat-inm", fmt.format(NAC.inmuebles));
        setStat("plv-stat-tit", fmt.format(NAC.titulares));
        setStat("plv-stat-gt", pct(NAC.pct));
        document.getElementById("plv-stat-gt-d").textContent =
          fmt.format(NAC.granTenedor) + " inmuebles · +" + UMBRAL;
        document.getElementById("plv-bar").style.width = Math.min(100, NAC.pct * 6) + "%";
        document.getElementById("plv-muni").textContent =
          fmt.format(NAC.municipios) + " municipios";
        return;
      }
      const s = statOf(d.properties.name);
      document.getElementById("plv-scope").textContent =
        s ? "Provincia seleccionada" : "Sin datos en el Catastro común";
      document.getElementById("plv-name").textContent = d.properties.display;
      if (!s) {
        ["plv-stat-inm", "plv-stat-tit", "plv-stat-gt"].forEach((i) => setStat(i, "—"));
        document.getElementById("plv-stat-gt-d").textContent = "catastro foral";
        document.getElementById("plv-bar").style.width = "0%";
        document.getElementById("plv-muni").textContent = "—";
        return;
      }
      setStat("plv-stat-inm", fmt.format(s.inmuebles));
      setStat("plv-stat-tit", fmt.format(s.titulares));
      setStat("plv-stat-gt", pct(s.pct));
      document.getElementById("plv-stat-gt-d").textContent =
        fmt.format(s.granTenedor) + " inmuebles · +" + UMBRAL;
      document.getElementById("plv-bar").style.width = Math.min(100, s.pct * 6) + "%";
      document.getElementById("plv-muni").textContent =
        fmt.format(s.municipios) + " municipios";
    }

    layout();
    fillPanel(null);
    regions.style("opacity", 0).transition()
      .delay((d, i) => 80 + i * 12).duration(420).style("opacity", 1);

    window.addEventListener("resize", layout);
  })();
</script>

<style>
  .plv-map-section {
    padding: clamp(2rem, 5vw, 4rem) clamp(1rem, 4vw, 3rem);
    color: var(--color-base-content);
  }
  .plv-head { max-width: 60ch; margin: 0 auto 2rem; text-align: center; }
  .plv-eyebrow {
    font-family: ui-monospace, "SF Mono", monospace;
    letter-spacing: .22em; text-transform: uppercase; font-size: .72rem;
    color: var(--color-accent); margin: 0 0 .5rem;
  }
  .plv-title {
    font-size: clamp(1.9rem, 4vw, 3rem); font-weight: 800; line-height: 1.02;
    margin: 0 0 .75rem; letter-spacing: -0.02em;
  }
  .plv-sub { font-size: .98rem; line-height: 1.5; opacity: .8; margin: 0; }
  .plv-sub strong { color: var(--color-accent); font-weight: 700; }

  .plv-grid {
    display: grid; gap: 1.25rem;
    grid-template-columns: minmax(0, 1fr) minmax(300px, 360px);
    max-width: 1200px; margin: 0 auto;
    align-items: stretch;
  }

  .plv-stage {
    position: relative;
    background:
      radial-gradient(120% 90% at 30% 0%, var(--color-base-100), var(--color-base-200));
    border: var(--border, 1px) solid var(--color-base-300);
    border-radius: var(--radius-box, .75rem);
    overflow: hidden;
    min-height: 560px;
  }
  #plv-map { width: 100%; height: 100%; display: block; cursor: grab; min-height: 560px; }
  #plv-map:active { cursor: grabbing; }

  :global(.plv-region) {
    stroke: var(--color-base-100);
    stroke-width: .6px; stroke-linejoin: round;
    cursor: pointer; outline: none;
    transition: filter .18s ease, opacity .18s ease;
  }
  :global(.plv-region:hover) { filter: brightness(1.07) saturate(1.1); }
  :global(.plv-region.dim) { opacity: .55; }
  :global(.plv-region.sel) { filter: brightness(1.04) saturate(1.2); }
  :global(.plv-region:focus-visible) { stroke: var(--color-accent); }

  .plv-tip {
    position: absolute; z-index: 10; pointer-events: none;
    padding: 6px 10px; border-radius: .4rem;
    background: var(--color-neutral); color: var(--color-neutral-content);
    font-size: .78rem; line-height: 1.25;
    transform: translate(-50%, -130%); opacity: 0;
    transition: opacity .14s ease; white-space: nowrap;
    box-shadow: 0 8px 20px rgba(0,0,0,.18);
  }

  .plv-reset {
    position: absolute; left: 1rem; bottom: 1rem; z-index: 6;
    opacity: 0; transform: translateY(6px); pointer-events: none;
    transition: opacity .25s ease, transform .25s ease;
  }
  .plv-reset.show { opacity: 1; transform: translateY(0); pointer-events: auto; }

  .plv-legend {
    position: absolute; right: 1rem; top: 1rem; z-index: 6;
    background: var(--color-base-100);
    backdrop-filter: blur(4px);
    border: var(--border,1px) solid var(--color-base-300);
    border-radius: .6rem; padding: .6rem .7rem; width: 168px;
  }
  .plv-legend-label { font-size: .62rem; letter-spacing: .04em; text-transform: uppercase; opacity: .75; }
  .plv-legend-bar { height: 9px; border-radius: 99px; margin: .4rem 0 .2rem; }
  .plv-legend-ticks { display: flex; justify-content: space-between; font-size: .6rem; opacity: .7; font-family: ui-monospace, monospace; }
  .plv-legend-na { display: flex; align-items: center; gap: .35rem; font-size: .62rem; margin-top: .45rem; opacity: .8; }
  .plv-na-swatch { width: 11px; height: 11px; border-radius: 2px; background: var(--color-base-300); border: 1px solid var(--color-base-content); }

  .plv-panel {
    display: flex; flex-direction: column;
    background: var(--color-base-100);
    border: var(--border,1px) solid var(--color-base-300);
    border-radius: var(--radius-box, .75rem);
    padding: 1.4rem 1.3rem;
  }
  .plv-scope {
    font-family: ui-monospace, monospace; font-size: .66rem;
    letter-spacing: .14em; text-transform: uppercase; color: var(--color-accent);
    margin: 0 0 .3rem;
  }
  .plv-name {
    font-size: 1.9rem; font-weight: 800; line-height: 1; margin: 0 0 1rem;
    letter-spacing: -0.02em; min-height: 1.9rem;
  }
  .plv-stats { width: 100%; background: var(--color-base-200); }
  .plv-stats .stat-value { font-size: 1.7rem; }

  .plv-bar-wrap { margin-top: 1.1rem; }
  .plv-bar-track {
    height: 8px; border-radius: 99px; background: var(--color-base-300); overflow: hidden;
  }
  .plv-bar-fill {
    height: 100%; width: 0%; border-radius: 99px;
    background: linear-gradient(90deg, var(--color-primary), var(--color-accent));
    transition: width .6s cubic-bezier(.2,.7,.2,1);
  }
  .plv-muni { font-size: .76rem; opacity: .7; margin: .5rem 0 0; font-family: ui-monospace, monospace; }

  .plv-foot { font-size: .68rem; line-height: 1.45; opacity: .55; margin: auto 0 0; padding-top: 1.2rem; }

  @media (max-width: 820px) {
    .plv-grid { grid-template-columns: 1fr; }
    .plv-stage { min-height: 440px; }
    #plv-map { min-height: 440px; }
  }
</style>
