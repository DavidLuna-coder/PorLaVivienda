---
import Stat from "./Stat.astro";
---

<div class="hero bg-base-200 min-h-screen">
    <div class="hero kg:min-w-4xl text-center flex flex-col">
        <div class="max-w-md">
            <h1 class="text-6xl font-bold">Por la vivienda</h1>
            <p class="py-6">
                En un mundo de multipropietarios el derecho a la vivienda no es
                prioritario.
            </p>
        </div>
        <div class="grid grid-cols-2 sm:grid-flow-row grid-rows-3 gap-2 min-w-xs md:min-w-2xl lg:min-w-6xl">
            <Stat class="col-span-full" />
            <Stat class= "col-span-full md:col-span-1"/>
            <Stat class= "col-span-full md:col-span-1"/>
        </div>
    </div>
</div>
